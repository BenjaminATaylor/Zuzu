process.container = 'benjaminataylor/zuzu:latest'
docker.enabled = true

process {
    withLabel: small_job {
        cpus = 1
        memory = '1 GB'
        time = '5m'
    }
    withLabel: mid_job {
        cpus = 1
        memory = '5 GB'
        time = '1h'
    }
    withLabel: big_job {
        cpus = 10
        memory = '20 GB'
        time = '1d'
    }
}

profiles {
    local {
        params.njobs = 1
    }
    cluster {
        params.njobs = -1
        process {
            withLabel: big_job {
                memory = '30 GB'
            }
        }
    }
}